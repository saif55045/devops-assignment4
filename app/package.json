{
  "name": "devops-sample-app",
  "version": "1.0.0",
  "description": "Sample Node.js Express application for DevOps Assignment 4 CI/CD pipeline",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit --detectOpenHandles --ci --reporters=default --reporters=jest-junit",
    "test:int": "jest tests/integration --forceExit --detectOpenHandles --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint src/ tests/"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "clover"
    ]
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
